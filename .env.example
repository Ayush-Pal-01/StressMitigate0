# StressMitigate — Environment Variables Template
# Copy this to .env and fill in your actual values.
# NEVER commit the real .env file to source control!

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=stress_mitigate

# JWT Authentication
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CHANGE_ME_generate_a_64byte_random_string

# Sentry Error Tracking (optional)
# Get your DSN from https://sentry.io
SENTRY_DSN=

# Environment
ENVIRONMENT=development
